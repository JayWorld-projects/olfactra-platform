# ─────────────────────────────────────────────────────────────
# Olfactra — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# MySQL/TiDB connection string (used by Drizzle ORM and server)
DATABASE_URL=

# ── Authentication ───────────────────────────────────────────
# Secret key for signing JWT session cookies
JWT_SECRET=

# Manus OAuth application ID
VITE_APP_ID=

# Manus OAuth backend base URL (server-side token exchange)
OAUTH_SERVER_URL=

# Manus OAuth login portal URL (frontend redirect)
VITE_OAUTH_PORTAL_URL=

# ── Owner ────────────────────────────────────────────────────
# Owner's Manus OpenID (used for admin identification)
OWNER_OPEN_ID=

# Owner's display name
OWNER_NAME=

# ── Forge API (AI, Storage, Maps, Notifications) ────────────
# Server-side Forge API base URL
BUILT_IN_FORGE_API_URL=

# Server-side Forge API bearer token (SECRET — never expose to frontend)
BUILT_IN_FORGE_API_KEY=

# Frontend-scoped Forge API URL
VITE_FRONTEND_FORGE_API_URL=

# Frontend-scoped Forge API key (limited permissions, safe for browser)
VITE_FRONTEND_FORGE_API_KEY=

# ── Analytics (Umami) ────────────────────────────────────────
# Umami analytics script endpoint
VITE_ANALYTICS_ENDPOINT=

# Umami website tracking ID
VITE_ANALYTICS_WEBSITE_ID=

# ── Branding ─────────────────────────────────────────────────
# Application display title
VITE_APP_TITLE=Olfactra

# Application logo URL (CDN or relative path)
VITE_APP_LOGO=
